GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
DATABASE_URL=./db/td_demo.db
CORS_ORIGINS=http://localhost:3000
DEBUG=false
SEED_DB=true

# Локальный Ollama — start.py выставляет автоматически (true если Ollama установлен)
# Groq используется как запасной вариант, если Ollama недоступен
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=yandex/YandexGPT-5-Lite-8B-instruct-GGUF:latest
